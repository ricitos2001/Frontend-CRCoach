# =============================================================================
# CRCoach - Frontend Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials to version control
# =============================================================================

# Port for local development server
PORT=4200

# API URL (uses relative path for Nginx reverse proxy in production)
# In development, you may need to point to the backend directly:
# API_URL=http://localhost:8080
